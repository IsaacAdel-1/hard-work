# Copy this file to ".env" and fill in real values.

# MongoDB Atlas connection string (required for the account API).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net

# Database name (optional — defaults to "workhard").
MONGODB_DB=workhard

# Secret used to sign JWT auth tokens. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# Port the server listens on (optional — hosting platforms set this automatically).
PORT=4000
